{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "preview"
    },
    "testflight": {
      "autoIncrement": true,
      "channel": "preview",
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {},
      "channel": "production"
    }
  },
  "submit": {
    "production": {},
    "testflight": {
      "ios": {
        "appleTeamId": "VL5QP7VU37"
      }
    }
  }
}

<?xml version="1.0" encoding="utf-8"?>
<!--
  Piqabu Keyboard root layout.

  Two zones:
    1. Strip (48 dp)    — identity + status + MINT + globe.
    2. QWERTY (≈200 dp) — KeyboardView, dual-mode (Phase 2.6).

  Lock overlay is a FrameLayout sibling at the root that covers everything
  when LOCKED state is active. Tap-to-unlock fires BiometricPrompt.

  The previous "Piqabu Tools" row (ZERO TRACE indicator + VANISH + PASTE
  buttons) was removed at the user's request — the keyboard reads cleaner
  without it. Ghost Paste / vanishing-send live on as in-app features and
  can return to the keyboard later in a less obtrusive form.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/piqabu_keyboard_bg">

        <!-- Strip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:background="@color/piqabu_keyboard_bg">

            <View
                android:id="@+id/piqabu_pulse_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/piqabu_pulse_dot"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/piqabu_status_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/piqabu_keyboard_status_idle"
                android:textColor="@color/piqabu_keyboard_ink"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"/>

            <!-- OPEN button — hidden when idle, revealed after MINT so the
                 user has an explicit affordance to launch Piqabu. -->
            <Button
                android:id="@+id/piqabu_open_button"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:text="@string/piqabu_keyboard_open"
                android:textColor="@color/piqabu_keyboard_ink"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:fontFamily="monospace"
                android:letterSpacing="0.18"
                android:paddingHorizontal="14dp"
                android:paddingVertical="0dp"
                android:background="@drawable/piqabu_mint_button_bg"
                android:layout_marginEnd="6dp"
                android:visibility="gone"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/piqabu_mint_button"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:text="@string/piqabu_keyboard_mint"
                android:textColor="@color/piqabu_keyboard_ink"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:fontFamily="monospace"
                android:letterSpacing="0.18"
                android:paddingHorizontal="14dp"
                android:paddingVertical="0dp"
                android:background="@drawable/piqabu_mint_button_bg"
                android:layout_marginEnd="8dp"
                android:stateListAnimator="@null"/>

            <ImageButton
                android:id="@+id/piqabu_globe_button"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/piqabu_ic_globe"
                android:background="@drawable/piqabu_globe_button_bg"
                android:contentDescription="@string/piqabu_keyboard_globe_desc"
                android:scaleType="centerInside"/>
        </LinearLayout>

        <!--
          QWERTY body (Phase 2.6). Uses Android's built-in KeyboardView.
          Pre-MINT (dual-mode), key events route to the host app's input
          field. Post-MINT (Phase 4), they'll route to the Piqabu peer.
        -->
        <android.inputmethodservice.KeyboardView
            android:id="@+id/piqabu_keyboard_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/piqabu_keyboard_bg_dim"
            android:keyBackground="@drawable/piqabu_key_bg"
            android:keyTextColor="@color/piqabu_keyboard_ink"
            android:keyTextSize="18sp"
            android:labelTextSize="14sp"
            android:keyPreviewLayout="@layout/piqabu_key_preview"
            android:shadowColor="@android:color/transparent"
            android:shadowRadius="0"/>
    </LinearLayout>

    <!-- Lock overlay (Phase 3.4) — fully opaque, covers strip + QWERTY
         when locked. Tap fires BiometricPrompt. Visibility toggled by code. -->
    <LinearLayout
        android:id="@+id/piqabu_lock_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/piqabu_keyboard_bg"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <View
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/piqabu_pulse_dot"
            android:layout_marginBottom="14dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/piqabu_keyboard_status_locked"
            android:textColor="@color/piqabu_keyboard_ink"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:fontFamily="monospace"
            android:letterSpacing="0.25"/>
    </LinearLayout>
</FrameLayout>

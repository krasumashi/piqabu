<?xml version="1.0" encoding="utf-8"?>
<!-- MINT button background — subtle hairline border, monochrome. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/piqabu_keyboard_button_pressed"/>
            <corners android:radius="10dp"/>
            <stroke android:width="1dp" android:color="@color/piqabu_keyboard_edge"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/piqabu_keyboard_button"/>
            <corners android:radius="10dp"/>
            <stroke android:width="1dp" android:color="@color/piqabu_keyboard_edge"/>
        </shape>
    </item>
</selector>

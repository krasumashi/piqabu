{
  "expo": {
    "name": "Piqabu",
    "slug": "client",
    "scheme": "piqabu",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060709"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.krasumashi.piqabu",
      "buildNumber": "3",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Piqabu uses the camera only when you start a Live Glass session, so you and your conversation partner can see each other privately.",
        "NSMicrophoneUsageDescription": "Piqabu uses the microphone only when you start a Whisper or Live Glass session.",
        "NSPhotoLibraryUsageDescription": "Piqabu can read images from your photo library when you choose to reveal them to a conversation partner. Images stay private and ephemeral.",
        "NSFaceIDUsageDescription": "Piqabu uses Face ID for biometric lock if you enable it in Settings.",
        "LSApplicationQueriesSchemes": [
          "whatsapp",
          "mailto"
        ]
      },
      "associatedDomains": [
        "applinks:piqabu.live"
      ],
      "bitcode": false,
      "appleTeamId": "VL5QP7VU37"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#060709"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.krasumashi.piqabu",
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "extra": {
      "eas": {
        "projectId": "eb9a4e25-cfdd-4c53-b25c-d5e52973595c"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#060709",
          "image": "./assets/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-document-picker",
      "expo-local-authentication",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Piqabu uses the camera for the Live Glass feature",
          "microphonePermission": "Piqabu uses the microphone for Whisper and Live Glass"
        }
      ],
      "./plugins/withMediaProjectionService.js",
      "expo-web-browser",
      "react-native-iap",
      "./plugins/withEasIosBuildNumber.js",
      "@bacons/apple-targets"
    ],
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/eb9a4e25-cfdd-4c53-b25c-d5e52973595c",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    }
  }
}

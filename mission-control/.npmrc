# Mission Control build-time configuration.
#
# Render sets NODE_ENV=production at the service level, which makes
# `npm install` skip devDependencies by default — but vite, tsc,
# tailwind, postcss and autoprefixer all live there (correctly, since
# they're build-time only). Forcing include=dev here means the build
# tools always get installed in this folder, regardless of how the
# parent service's build command is configured.
include=dev
